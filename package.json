{
  "name": "tag-youre-it",
  "version": "1.0.0",
  "description": "Make the meaning clear. This plugin enables semantic tagging of web content.",
  "main": "Gulpfile.js",
  "scripts": {
    "clean": "rm -r dist node_modules || true",
    "build": "webpack && ./build.sh",
    "test:dist": "karma start",
    "start": "browser-sync start --no-notify -b chromium --startPath test/ --server --files 'src/**/*'",
    "package": "npm run build && ./package.sh",
    "webpack": "webpack",
    "webpack:watch": "webpack --watch",
    "karma": "karma"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nilsnh/tag-youre-it.git"
  },
  "private": true,
  "keywords": [
    "semantic",
    "web",
    "tagging"
  ],
  "author": "Nils Norman Haukås <nils@thunki.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nilsnh/tag-youre-it/issues"
  },
  "homepage": "https://github.com/nilsnh/tag-youre-it",
  "dependencies": {
    "@types/angular": "^1.5.10",
    "@types/angular-mocks": "^1.5.10",
    "@types/chrome": "0.0.46",
    "@types/jasmine": "^2.5.53",
    "@types/jquery": "^2.0.41",
    "@types/lodash": "^4.14.62",
    "@types/ngstorage": "^0.3.34",
    "@types/rangy": "0.0.27",
    "@types/uuid": "^2.0.29",
    "angular": "1.5.10",
    "angular-mocks": "1.5.10",
    "browser-sync": "^2.18.8",
    "jquery": "^3.0.0",
    "lodash": "4.12.0",
    "material-design-lite": "^1.1.3",
    "ngstorage": "0.3.10",
    "rangy": "^1.3.0",
    "ts-loader": "^2.0.3",
    "typescript": "^2.2.2",
    "uuid": "3.0.1",
    "webpack": "^2.4.1"
  },
  "devDependencies": {
    "jasmine-core": "^2.6.2",
    "karma": "^1.7.0",
    "karma-chrome-launcher": "^2.1.1",
    "karma-es6-shim": "^1.0.0",
    "karma-jasmine": "^1.1.0",
    "karma-requirejs": "^1.1.0",
    "karma-typescript": "^3.0.3",
    "karma-typescript-es6-transform": "^1.0.1",
    "requirejs": "^2.3.3"
  }
}
